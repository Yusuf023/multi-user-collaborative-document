# ─── Optional (all have defaults — bare-metal demo runs with zero config) ────

# Node environment (default: development; one of: development, test, production)
NODE_ENV=development

# Pino log level (default: info; one of: fatal, error, warn, info, debug, trace, silent)
LOG_LEVEL=info

# Server port (default: 4000)
PORT=4000

# SQLite database file (default: ./data/poc.db)
# Parent directory is created automatically on first boot.
SQLITE_PATH=./data/poc.db

# Per-document cache directory — in-memory map + one file per doc (default: ./data/cache)
# Survives process restart; lost on pod replacement (DB snapshot recovers state).
CACHE_DIR=./data/cache

# SMTP relay for invite emails. Leave SMTP_HOST blank to disable email sending
# (invite links are logged instead).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# "From" address for invite emails (default: No Reply <noreply@example.com>)
MAIL_FROM=No Reply <noreply@yourdomain.com>

# Frontend URL used in invite email links (default: http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# Allowed CORS origin for the frontend (default: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# Debounce interval (ms) for flushing Yjs state from cache to SQLite (default: 3000)
DB_FLUSH_INTERVAL_MS=3000

# Rate limiting window (ms) for create/join endpoints (default: 60000)
RATE_LIMIT_WINDOW_MS=60000

# Max requests per rate limit window (default: 10)
RATE_LIMIT_MAX_REQUESTS=10

# ─── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/collab_docs

# Redis connection string (primary store for real-time Yjs document state)
REDIS_URL=redis://default:password@localhost:6379

# Resend API key for sending invite emails (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# ─── Optional (have defaults) ────────────────────────────────────────────────

# Server port (default: 4000)
PORT=4000

# "From" address for invite emails (default: noreply@example.com)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Frontend URL used in invite email links (default: http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# Allowed CORS origin for the frontend (default: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# Debounce interval (ms) for flushing Yjs state from Redis to Postgres (default: 3000)
DB_FLUSH_INTERVAL_MS=3000

# Rate limiting window (ms) for create/join endpoints (default: 60000)
RATE_LIMIT_WINDOW_MS=60000

# Max requests per rate limit window (default: 10)
RATE_LIMIT_MAX_REQUESTS=10
